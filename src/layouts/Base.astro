---
import { SITE } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const { title, description, image = '/og.png' } = Astro.props;
const pageTitle = title ? `${title} · getcroquis` : SITE.title;
const pageDesc = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).href;

// Datos estructurados de marca: ayudan a Google a entender el sitio (sitelinks,
// nombre de marca, caja de búsqueda). Se incluyen en todas las páginas.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'getcroquis',
  alternateName: 'Croquis',
  url: SITE.url,
  logo: `${SITE.url}/og.png`,
  description: SITE.description,
  sameAs: [SITE.instagram],
};
const siteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'getcroquis',
  alternateName: 'Croquis',
  url: SITE.url,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${SITE.url}/destinos?buscar={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0d12" />
    <link rel="icon" type="image/png" href="/favicon-32.png" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="getcroquis" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, SITE.url).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={new URL(image, SITE.url).href} />

    <!-- Datos estructurados de marca (Organization + WebSite con buscador) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(siteLd)} />

    <!-- Tipografía de marca (más personalidad que la del sistema) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      body { font-family: 'Sora', system-ui, -apple-system, sans-serif; }
      h1, h2, h3 { letter-spacing: -0.02em; }
      .reveal { opacity: 0; transform: translateY(18px); transition: opacity .6s ease, transform .6s cubic-bezier(.2,.7,.2,1); }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; transition: none; } }
    </style>
  </head>
  <body class="min-h-screen bg-[#0a0d12] text-white antialiased selection:bg-tirma-pink/30">
    <div class="pointer-events-none fixed inset-0 overflow-hidden -z-10">
      <div class="absolute -top-44 -left-40 w-[720px] h-[720px] rounded-full bg-tirma-deep/[0.13] blur-[130px]"></div>
      <div class="absolute -top-24 right-0 w-[520px] h-[520px] rounded-full bg-tirma-pink/[0.07] blur-[120px]"></div>
      <div class="absolute top-1/3 -right-40 w-[560px] h-[560px] rounded-full bg-[#6d28d9]/[0.09] blur-[130px]"></div>
      <div class="absolute bottom-[-12%] left-1/4 w-[660px] h-[520px] rounded-full bg-tirma-beige/[0.05] blur-[130px]"></div>
    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      // Animación de entrada: revela secciones al hacer scroll (mejora progresiva).
      const els = document.querySelectorAll('main section, main > div > section');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
        els.forEach((el) => { el.classList.add('reveal'); io.observe(el); });
      }
    </script>
  </body>
</html>
