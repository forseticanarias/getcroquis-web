---
import { SITE } from '../consts';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const { title, description, image = '/og.png' } = Astro.props;
const pageTitle = title ? `${title} · getcroquis` : SITE.title;
const pageDesc = description ?? SITE.description;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0d12" />
    <link rel="icon" type="image/png" href="/favicon-32.png" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="getcroquis" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(image, SITE.url).href} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={new URL(image, SITE.url).href} />

    <!-- Tipografía de marca (más personalidad que la del sistema) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      body { font-family: 'Sora', system-ui, -apple-system, sans-serif; }
      h1, h2, h3 { letter-spacing: -0.02em; }
    </style>
  </head>
  <body class="min-h-screen bg-[#0a0d12] text-white antialiased selection:bg-tirma-pink/30">
    <div class="pointer-events-none fixed inset-x-0 top-0 h-[500px] overflow-hidden -z-10">
      <div class="absolute -top-40 left-1/2 -translate-x-1/2 w-[700px] h-[700px] rounded-full bg-tirma-pink/10 blur-3xl"></div>
    </div>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
