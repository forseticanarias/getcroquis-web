---
import { SITE } from '../consts';
const year = new Date().getFullYear();

// Footer organizado en columnas (estilo blog de referencia): cada sección con
// sus enlaces. Los legales viven en la app (mismo dominio, /legal/*).
const cols = [
  {
    title: 'Explora',
    links: [
      { label: 'Empieza aquí', href: '/empezar' },
      { label: 'Destinos', href: '/destinos' },
      { label: 'Comparar países', href: '/comparar' },
      { label: 'Guías de viaje', href: '/guias' },
    ],
  },
  {
    title: 'Comunidad',
    links: [
      { label: 'Explora la comunidad', href: `${SITE.appUrl}/explora` },
      { label: 'Crear cuenta', href: `${SITE.appUrl}/signup` },
      { label: 'Abrir la app', href: `${SITE.appUrl}/dashboard` },
      { label: 'Síguenos en Instagram', href: SITE.instagram, external: true },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacidad', href: `${SITE.appUrl}/legal/privacidad` },
      { label: 'Política de cookies', href: `${SITE.appUrl}/legal/cookies` },
      { label: 'Términos de uso', href: `${SITE.appUrl}/legal/terminos` },
      { label: 'Aviso legal', href: `${SITE.appUrl}/legal/aviso-legal` },
    ],
  },
];
---
<footer class="relative z-10 border-t border-white/[0.06] mt-20">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-8">
      <!-- Marca -->
      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="font-black text-xl tracking-tight bg-gradient-to-r from-tirma-pink to-tirma-beige bg-clip-text text-transparent">
          getcroquis
        </a>
        <p class="mt-3 text-sm text-white/45 leading-relaxed max-w-[14rem]">
          Tu referente de viajes: planifica con IA, descubre destinos y comparte tus rutas.
        </p>
        <a href={SITE.instagram} target="_blank" rel="noopener" aria-label="Síguenos en Instagram"
           class="mt-4 inline-flex items-center gap-1.5 text-white/55 hover:text-tirma-pink transition text-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          @getcroquis
        </a>
      </div>

      <!-- Columnas de enlaces -->
      {cols.map((c) => (
        <div>
          <h3 class="text-xs font-bold tracking-widest text-white/40 uppercase mb-3">{c.title}</h3>
          <ul class="space-y-2">
            {c.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  target={l.external ? '_blank' : undefined}
                  rel={l.external ? 'noopener' : undefined}
                  class="text-sm text-white/60 hover:text-white transition"
                >{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Barra inferior -->
    <div class="mt-10 pt-6 border-t border-white/[0.06] flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-white/35">
      <span>© {year} Croquis · planifica y comparte tus viajes</span>
      <span>Hecho con cariño para viajeros 🌍</span>
    </div>
  </div>
</footer>
