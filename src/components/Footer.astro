---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---
<footer class="relative z-10 border-t border-white/[0.06] mt-20">
  <div class="max-w-5xl mx-auto px-6 py-8 flex flex-wrap items-center justify-between gap-3 text-xs text-white/40">
    <div class="flex items-center gap-4">
      <span>© {year} Croquis · <a href="/guias" class="hover:text-white/70">Guías de viaje</a></span>
      <a href={SITE.instagram} target="_blank" rel="noopener" aria-label="Síguenos en Instagram"
         class="inline-flex items-center gap-1.5 text-white/50 hover:text-tirma-pink transition">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
        <span class="hidden sm:inline">@getcroquis</span>
      </a>
    </div>
    <div class="flex gap-4">
      <a href={`${SITE.appUrl}/legal/privacidad`} class="hover:text-white/70">Privacidad</a>
      <a href={`${SITE.appUrl}/legal/terminos`} class="hover:text-white/70">Términos</a>
      <a href={`${SITE.appUrl}/dashboard`} class="hover:text-white/70">Abrir app</a>
    </div>
  </div>
</footer>
