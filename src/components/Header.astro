---
import { SITE } from '../consts';
const links = [
  { href: '/empezar', label: 'Empieza aquí', emoji: '🧭' },
  { href: '/destinos', label: 'Destinos', emoji: '🌍' },
  { href: '/comparar', label: 'Comparar', emoji: '⚖️' },
  { href: '/guias', label: 'Guías', emoji: '📚' },
  { href: `${SITE.appUrl}/explora`, label: 'Explora la comunidad', emoji: '✨' },
];
---
<header class="relative z-30 max-w-5xl mx-auto px-5 sm:px-6 py-4 flex items-center justify-between gap-2">
  <a href="/" class="font-black text-xl sm:text-2xl tracking-tight bg-gradient-to-r from-tirma-pink to-tirma-beige bg-clip-text text-transparent">
    getcroquis
  </a>

  <!-- Escritorio -->
  <nav class="hidden sm:flex items-center gap-1.5 text-sm">
    <a href="/empezar" class="text-tirma-beige/90 hover:text-tirma-beige font-semibold px-3 py-1.5">Empieza aquí</a>
    <a href="/destinos" class="text-white/60 hover:text-white px-3 py-1.5">Destinos</a>
    <a href="/comparar" class="text-white/60 hover:text-white px-3 py-1.5">Comparar</a>
    <a href="/guias" class="text-white/60 hover:text-white px-3 py-1.5">Guías</a>
    <a href={`${SITE.appUrl}/dashboard`} class="font-bold px-3.5 py-1.5 rounded-full bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige shadow-lg shadow-tirma-pink/25 whitespace-nowrap">Abrir app</a>
  </nav>

  <!-- Móvil: Abrir app + menú -->
  <div class="flex items-center gap-2 sm:hidden">
    <a href={`${SITE.appUrl}/dashboard`} class="font-bold text-xs px-3 py-2 rounded-full bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige whitespace-nowrap">Abrir app</a>
    <button id="menu-btn" aria-label="Abrir menú" class="w-10 h-10 rounded-full border border-white/15 bg-white/[0.04] flex items-center justify-center text-white">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>
</header>

<!-- Panel de menú móvil -->
<div id="mobile-menu" class="sm:hidden fixed inset-0 z-40 hidden">
  <div id="menu-overlay" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <nav class="absolute top-0 right-0 h-full w-72 max-w-[85%] bg-[#0d1016] border-l border-white/10 p-5 flex flex-col gap-1 animate-[slideIn_0.2s_ease]" style="padding-top: calc(1.25rem + env(safe-area-inset-top));">
    <div class="flex items-center justify-between mb-4">
      <span class="font-black text-lg bg-gradient-to-r from-tirma-pink to-tirma-beige bg-clip-text text-transparent">getcroquis</span>
      <button id="menu-close" aria-label="Cerrar" class="w-9 h-9 rounded-full border border-white/10 flex items-center justify-center text-white/70">✕</button>
    </div>
    {links.map((l) => (
      <a href={l.href} class="flex items-center gap-3 px-3 py-3 rounded-xl text-white/85 hover:bg-white/[0.06] font-semibold transition">
        <span class="text-lg">{l.emoji}</span>{l.label}
      </a>
    ))}
    <a href={`${SITE.appUrl}/dashboard`} class="mt-3 text-center px-4 py-3 rounded-xl bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold">Abrir la app →</a>
  </nav>
</div>

<style>
  @keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
</style>
<script>
  const menu = document.getElementById('mobile-menu');
  const open = () => menu?.classList.remove('hidden');
  const close = () => menu?.classList.add('hidden');
  document.getElementById('menu-btn')?.addEventListener('click', open);
  document.getElementById('menu-close')?.addEventListener('click', close);
  document.getElementById('menu-overlay')?.addEventListener('click', close);
</script>
