---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const guias = (await getCollection('guias', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Guías de viaje"
  description="Guías prácticas para preparar tu viaje: presupuesto, eSIM, cambio de divisa, seguro, documentación y más. Consejos que ahorran tiempo y dinero."
>
  <section class="max-w-3xl mx-auto px-5 sm:px-6 pt-10 sm:pt-14 pb-6">
    <p class="text-xs font-bold tracking-widest text-tirma-pink/80 uppercase mb-3">Guías de viaje</p>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Prepara tu viaje sin agobios</h1>
    <p class="mt-3 text-white/65 leading-relaxed">
      Lo esencial para viajar mejor y más barato, explicado claro y al grano.
    </p>
  </section>

  <section class="max-w-3xl mx-auto px-5 sm:px-6 pb-16">
    <div class="grid gap-4">
      {guias.map((g) => (
        <a href={`/guias/${g.slug}`} class="flex items-start gap-4 p-5 rounded-2xl bg-white/[0.03] border border-white/[0.08] hover:border-tirma-pink/30 hover:bg-white/[0.05] transition">
          <div class="text-2xl shrink-0">{g.data.emoji}</div>
          <div>
            <h2 class="font-bold text-lg leading-snug">{g.data.title}</h2>
            <p class="text-sm text-white/60 mt-1 leading-relaxed">{g.data.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
