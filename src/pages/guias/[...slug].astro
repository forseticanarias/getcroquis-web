---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const guias = await getCollection('guias', ({ data }) => !data.draft);
  return guias.map((g) => ({ params: { slug: g.slug }, props: { g } }));
}

const { g } = Astro.props;
const { Content } = await g.render();
---

<Base title={g.data.title} description={g.data.description}>
  <article class="max-w-2xl mx-auto px-5 sm:px-6 pt-8 sm:pt-12 pb-10">
    <a href="/guias" class="text-sm text-white/50 hover:text-white">← Guías</a>
    <div class="text-4xl mt-5 mb-3">{g.data.emoji}</div>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight leading-tight">{g.data.title}</h1>
    <p class="mt-3 text-lg text-white/65 leading-relaxed">{g.data.description}</p>

    <div class="prose prose-invert prose-headings:font-bold prose-a:text-tirma-beige max-w-none mt-8
                prose-table:text-sm prose-th:text-left prose-strong:text-white">
      <Content />
    </div>

    <div class="mt-12 p-6 rounded-2xl bg-gradient-to-br from-tirma-pink/12 to-transparent border border-tirma-pink/25 text-center">
      <p class="font-bold text-lg">Pon en práctica esta guía</p>
      <p class="text-sm text-white/65 mt-1">Crea tu itinerario en getcroquis y organiza todo el viaje en un sitio.</p>
      <a href={SITE.appUrl} class="inline-flex items-center gap-2 mt-4 px-7 py-3 rounded-full bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold shadow-lg shadow-tirma-pink/25 hover:brightness-105 transition">
        Planifica tu viaje gratis →
      </a>
    </div>
  </article>
</Base>
