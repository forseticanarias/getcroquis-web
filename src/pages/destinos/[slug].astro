---
import Base from '../../layouts/Base.astro';
import { SITE, ESSENTIALS } from '../../consts';
import { COUNTRIES } from '../../data/countries';

export async function getStaticPaths() {
  return COUNTRIES.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props;
const flag = `https://flagcdn.com/h40/${c.code}.png`;
const facts = [
  ['Capital', c.capital],
  ['Moneda', c.currency],
  ['Idioma', c.language],
  ['Visado', c.visa],
  ['Internet', c.internet],
  ['Duración ideal', c.duration],
  ['Dificultad', c.difficulty],
  ['Enchufe', c.plug],
  ['Zona horaria', c.tz],
  ['Presupuesto', c.budget],
].filter(([, v]) => v);

const RC = { good: 'bg-emerald-500/80', mid: 'bg-amber-500/80', avoid: 'bg-red-500/70' };
const budgetRows = c.budgetLevels
  ? [
      ['Mochilero', c.budgetLevels.mochilero],
      ['Normal', c.budgetLevels.normal],
      ['Cómodo', c.budgetLevels.comodo],
      ['Lujo', c.budgetLevels.lujo],
    ]
  : [];

// Esenciales HONESTOS según el destino: en la UE (roaming + Tarjeta Sanitaria
// Europea) la eSIM y el seguro bajan de nivel. Color por nivel de necesidad.
const EU_ROAMING = new Set(['es','pt','fr','it','gr','hr','is','de','nl','be','at','ie','dk','se','fi','pl','cz','hu','ro','bg','sk','si','ee','lv','lt','lu','mt','cy','no','li']);
const inEU = EU_ROAMING.has(c.code);
const NEED_COLORS: Record<string, string> = {
  'Imprescindible': 'bg-red-500/15 text-red-300 border-red-500/25',
  'Muy recomendable': 'bg-amber-500/15 text-amber-300 border-amber-500/25',
  'Recomendable': 'bg-sky-500/15 text-sky-300 border-sky-500/25',
  'Opcional': 'bg-white/[0.08] text-white/55 border-white/15',
  'Reserva con antelación': 'bg-tirma-pink/15 text-tirma-beige border-tirma-pink/25',
  'Ahorra dinero': 'bg-emerald-500/15 text-emerald-300 border-emerald-500/25',
};
const essentials = ESSENTIALS.map((e) => {
  if (e.title.includes('eSIM') && inEU) return { ...e, need: 'Opcional', desc: 'Con el roaming de la UE no la necesitas. Solo si quieres aún más datos.' };
  if (e.title.includes('Seguro') && inEU) return { ...e, need: 'Recomendable', desc: 'En la UE tienes la Tarjeta Sanitaria Europea; el seguro suma cancelación y equipaje.' };
  return e;
});

// SEO: datos estructurados (Google los lee para rich results).
const jsonld: any = {
  '@context': 'https://schema.org',
  '@type': 'TouristDestination',
  name: c.name,
  ...(c.summary && { description: c.summary }),
  ...(c.image && { image: c.image }),
  url: `${SITE.url}/destinos/${c.slug}`,
};
const faqLd = c.faq?.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: c.faq.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
    }
  : null;

// SEO: migas de pan (rich results) + enlazado interno a destinos relacionados.
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE.url },
    { '@type': 'ListItem', position: 2, name: 'Destinos', item: `${SITE.url}/destinos` },
    { '@type': 'ListItem', position: 3, name: c.name, item: `${SITE.url}/destinos/${c.slug}` },
  ],
};
const CONT_MAP: Record<string, string> = { jp: 'Asia', th: 'Asia', vn: 'Asia', it: 'Europa', is: 'Europa', fr: 'Europa', es: 'Europa', gr: 'Europa', pt: 'Europa', hr: 'Europa', gb: 'Europa', no: 'Europa', ie: 'Europa', de: 'Europa', nl: 'Europa', ch: 'Europa', mx: 'América', pe: 'América', us: 'América', co: 'América', cu: 'América', ar: 'América', cr: 'América', br: 'América', ma: 'África', eg: 'África', za: 'África', ke: 'África', tz: 'África', tr: 'Asia', id: 'Asia', ae: 'Asia', ph: 'Asia', in: 'Asia', cn: 'Asia', kr: 'Asia', jo: 'Asia', kh: 'Asia', lk: 'Asia', mv: 'Asia' };
const sameCont = COUNTRIES.filter((x) => x.slug !== c.slug && CONT_MAP[x.code] === CONT_MAP[c.code]);
const otherCont = COUNTRIES.filter((x) => x.slug !== c.slug && CONT_MAP[x.code] !== CONT_MAP[c.code]);
const related = [...sameCont, ...otherCont].slice(0, 6);
---

<Base
  title={`${c.name}: mejor época, presupuesto y guía`}
  description={`Cuándo viajar a ${c.name}: mejor época, clima por estación, presupuesto, esenciales y consejos. ${c.summary?.slice(0, 80) ?? ''}`}
  image={c.image}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} />
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumb)} />

  <!-- HERO con foto icónica -->
  <header class="relative h-[44vh] min-h-[300px] max-h-[460px] w-full overflow-hidden">
    {c.image && <img src={c.image} alt={c.imageAlt ?? c.name} loading="eager" fetchpriority="high" class="absolute inset-0 w-full h-full object-cover" />}
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0d12] via-[#0a0d12]/40 to-[#0a0d12]/10"></div>
    <div class="relative z-10 max-w-5xl mx-auto h-full px-5 sm:px-6 flex flex-col justify-end pb-7">
      <a href="/destinos" class="absolute top-4 left-5 sm:left-6 text-sm text-white/80 hover:text-white bg-black/30 backdrop-blur px-3 py-1.5 rounded-full">← Destinos</a>
      <div class="flex items-center gap-3 mb-2">
        <img src={flag} alt={`Bandera de ${c.name}`} width="44" class="rounded-md ring-1 ring-white/25 shadow-lg" />
        {c.budget && <span class="text-xs font-semibold px-2.5 py-1 rounded-full bg-white/15 backdrop-blur">{c.budget}</span>}
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight drop-shadow-lg">{c.name}</h1>
      {c.bestMonths && <p class="text-base sm:text-lg text-tirma-beige mt-2 drop-shadow">Mejor época: <strong>{c.bestMonths}</strong></p>}
    </div>
  </header>

  <div class="max-w-5xl mx-auto px-5 sm:px-6 py-10 grid lg:grid-cols-3 gap-8">
    <!-- COLUMNA PRINCIPAL -->
    <div class="lg:col-span-2 space-y-10 order-2 lg:order-1">
      <div class="space-y-3">
        {c.summary && <p class="text-lg text-white/90 font-medium leading-relaxed">{c.summary}</p>}
        {c.tags && c.tags.length > 0 && (
          <div class="flex flex-wrap items-center gap-2">
            <span class="text-xs font-bold uppercase tracking-wider text-white/40">Ideal para</span>
            {c.tags.map((t) => (
              <span class="px-3 py-1 rounded-full bg-white/[0.05] border border-white/10 text-xs text-white/70">{t}</span>
            ))}
          </div>
        )}
      </div>

      <div class="lg:hidden flex flex-wrap gap-2">
        {facts.map(([k, v]) => (
          <span class="text-xs px-2.5 py-1 rounded-full bg-white/[0.04] border border-white/[0.08]"><span class="text-white/40">{k}:</span> <span class="font-semibold">{v}</span></span>
        ))}
      </div>

      {c.seasons && c.seasons.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-4">¿Cuándo ir a {c.name}?</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            {c.seasons.map((s) => (
              <div class="rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
                <div class="flex items-baseline justify-between mb-2">
                  <h3 class="font-bold">{s.name}</h3>
                  <span class="text-xs text-white/45">{s.months}</span>
                </div>
                <ul class="space-y-1 text-sm">
                  {s.pros.map((p) => <li class="text-emerald-300/90">✓ {p}</li>)}
                  {s.cons.map((co) => <li class="text-white/45">✕ {co}</li>)}
                </ul>
              </div>
            ))}
          </div>
        </section>
      )}

      {c.climate && c.climate.length === 12 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Calendario: mes a mes</h2>
          <div class="grid grid-cols-6 sm:grid-cols-12 gap-1.5">
            {c.climate.map((mo) => (
              <div class="text-center">
                <div class={`h-9 rounded-lg ${RC[mo.r]} flex items-center justify-center text-[11px] font-bold text-white/90`}>{mo.m}</div>
              </div>
            ))}
          </div>
          <div class="flex flex-wrap gap-4 mt-3 text-xs text-white/50">
            <span class="flex items-center gap-1.5"><i class="w-3 h-3 rounded bg-emerald-500/80"></i> Buena época</span>
            <span class="flex items-center gap-1.5"><i class="w-3 h-3 rounded bg-amber-500/80"></i> Aceptable</span>
            <span class="flex items-center gap-1.5"><i class="w-3 h-3 rounded bg-red-500/70"></i> A evitar</span>
          </div>
        </section>
      )}

      {budgetRows.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">¿Cuánto cuesta al día?</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {budgetRows.map(([label, val]) => (
              <div class="rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4 text-center">
                <div class="text-sm text-white/60">{label}</div>
                <div class="text-2xl font-bold mt-1">{val}€</div>
                <div class="text-[11px] text-white/40">por día</div>
              </div>
            ))}
          </div>
          <p class="text-xs text-white/40 mt-2">Orientativo por persona, sin contar el vuelo.</p>
        </section>
      )}

      {c.cityGuides && c.cityGuides.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-1">Ciudades: cuánto tiempo y qué ver</h2>
          <p class="text-sm text-white/50 mb-4">Despliega cada ciudad para ver el ranking y los enlaces.</p>
          <div class="space-y-2.5">
            {c.cityGuides.map((city, i) => (
              <details class="group rounded-2xl bg-white/[0.03] border border-white/[0.08]" open={i === 0}>
                <summary class="cursor-pointer list-none p-4 flex items-center gap-3">
                  <span class="text-base font-bold">{city.name}</span>
                  {city.days && <span class="text-[11px] font-semibold px-2 py-0.5 rounded-full bg-tirma-pink/15 text-tirma-beige/90">{city.days}</span>}
                  <span class="ml-auto text-tirma-pink text-xl leading-none transition-transform group-open:rotate-45">+</span>
                </summary>
                <div class="px-4 pb-4">
                  {(city.image || city.fact) && (
                    <div class="flex flex-col sm:flex-row gap-4 mb-4 sm:items-center">
                      {city.image && <img src={city.image} alt={city.name} loading="lazy" class="w-full sm:w-2/5 aspect-[4/3] object-cover rounded-xl flex-shrink-0" />}
                      {city.fact && (
                        <div class="sm:flex-1 rounded-xl bg-tirma-pink/[0.07] border border-tirma-pink/20 p-3.5">
                          <span class="text-tirma-pink font-bold text-[11px] uppercase tracking-wider">💡 ¿Sabías que…?</span>
                          <p class="text-sm text-white/75 leading-relaxed mt-1">{city.fact}</p>
                        </div>
                      )}
                    </div>
                  )}
                  {city.sights && (
                    <ol class="space-y-2">
                      {city.sights.map((s, j) => (
                        <li class="flex gap-2.5 text-sm">
                          <span class="text-tirma-pink/70 font-bold flex-shrink-0">{j + 1}.</span>
                          <span class="min-w-0">
                            {s.url
                              ? <a href={s.url} target="_blank" rel="noreferrer sponsored" class="text-tirma-beige/90 hover:text-tirma-beige underline underline-offset-2">{s.name} ↗</a>
                              : <span class="text-white/80">{s.name}</span>}
                            {s.note && <span class="block text-xs text-white/45 mt-0.5">💡 {s.note}</span>}
                          </span>
                        </li>
                      ))}
                    </ol>
                  )}
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      {!c.cityGuides && c.topSights && c.topSights.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-4">Top {c.topSights.length}: qué ver en {c.name}</h2>
          <ol class="space-y-2.5">
            {c.topSights.map((s, i) => (
              <li class="flex gap-3 rounded-2xl bg-white/[0.03] border border-white/[0.08] p-3.5">
                <span class="flex-shrink-0 w-7 h-7 rounded-full bg-tirma-pink/15 text-tirma-pink font-bold text-sm flex items-center justify-center">{i + 1}</span>
                <div class="min-w-0">
                  <div class="font-semibold leading-snug">{s.name}{s.city && <span class="text-white/40 font-normal"> · {s.city}</span>}</div>
                  {s.note && <div class="text-xs text-white/55 mt-0.5">💡 {s.note}</div>}
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      {!c.cityGuides && c.cities && c.cities.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Datos curiosos de sus ciudades</h2>
          <div class="space-y-3">
            {c.cities.map((ci) => (
              <div class="rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
                <div class="font-bold text-tirma-beige/90">{ci.name}</div>
                <p class="text-sm text-white/65 mt-1 leading-relaxed">{ci.fact}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      {!c.cityGuides && c.regions && c.regions.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Zonas destacadas</h2>
          <div class="flex flex-wrap gap-2">
            {c.regions.map((r) => (
              <span class="px-3 py-1.5 rounded-full bg-tirma-pink/10 border border-tirma-pink/25 text-sm text-tirma-beige/90">{r}</span>
            ))}
          </div>
        </section>
      )}

      {c.tips && c.tips.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Consejos clave</h2>
          <ul class="space-y-2">
            {c.tips.map((t) => (
              <li class="flex gap-2 text-white/75"><span class="text-tirma-pink font-bold">›</span>{t}</li>
            ))}
          </ul>
        </section>
      )}
      {(c.english || c.difficultyNote || (c.paperwork && c.paperwork.length > 0)) && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Antes de ir: comunicación y papeleo</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            {(c.english || c.difficultyNote) && (
              <div class="rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
                <div class="text-sm font-bold mb-1">🗣️ Comunicación</div>
                {c.english && <p class="text-sm text-white/65 leading-relaxed">{c.english}</p>}
                {c.difficultyNote && <p class="text-xs text-white/45 mt-2 leading-relaxed">Dificultad: {c.difficultyNote}</p>}
              </div>
            )}
            {c.paperwork && c.paperwork.length > 0 && (
              <div class="rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
                <div class="text-sm font-bold mb-1">📄 Papeleo necesario</div>
                <p class="text-[11px] text-white/40 mb-2">🇪🇸 Requisitos para <strong class="text-white/55">pasaporte español</strong>. Con otra nacionalidad, consulta los de tu país.</p>
                <ul class="text-sm text-white/65 space-y-1 mt-1">
                  {c.paperwork.map((p) => <li class="flex gap-2"><span class="text-tirma-pink">·</span>{p}</li>)}
                </ul>
              </div>
            )}
          </div>
        </section>
      )}

      {c.links && c.links.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Enlaces de interés</h2>
          <ul class="space-y-1.5">
            {c.links.map((l) => (
              <li>
                <a href={l.url} target="_blank" rel="noreferrer" class="text-tirma-beige/90 hover:text-tirma-beige underline underline-offset-2 text-sm">{l.label} ↗</a>
              </li>
            ))}
            <li>
              <a href="https://www.exteriores.gob.es/es/ServiciosAlCiudadano/Paginas/Registro-de-viajeros.aspx" target="_blank" rel="noreferrer" class="text-tirma-beige/90 hover:text-tirma-beige underline underline-offset-2 text-sm">🛂 Regístrate como viajero en el Ministerio (recomendado) ↗</a>
            </li>
          </ul>
        </section>
      )}

      {c.opinion && (
        <section class="rounded-2xl bg-gradient-to-br from-tirma-pink/[0.08] to-transparent border border-tirma-pink/20 p-5 sm:p-6">
          <h2 class="text-2xl font-bold mb-2">Mi opinión sobre {c.name} 💬</h2>
          <p class="text-white/85 leading-relaxed">{c.opinion}</p>
        </section>
      )}

      {c.faq && c.faq.length > 0 && (
        <section>
          <h2 class="text-2xl font-bold mb-3">Preguntas frecuentes</h2>
          <div class="space-y-2">
            {c.faq.map((f) => (
              <details class="group rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
                <summary class="font-semibold cursor-pointer list-none flex justify-between items-center gap-3">
                  {f.q}
                  <span class="text-tirma-pink transition-transform group-open:rotate-45 text-xl leading-none">+</span>
                </summary>
                <p class="text-sm text-white/65 mt-2 leading-relaxed">{f.a}</p>
              </details>
            ))}
          </div>
        </section>
      )}
      <p class="text-xs text-white/40 leading-relaxed border-t border-white/[0.06] pt-5">
        ℹ️ Información <strong class="text-white/55">orientativa</strong>, basada en estadísticas y experiencia de viaje. Cada viajero debe valorar su propio ritmo, presupuesto y circunstancias. Tómala como una guía para inspirarte, nunca como una regla fija.
      </p>
    </div>

    <!-- BARRA LATERAL (datos + esenciales + CTA) -->
    <aside class="space-y-5 lg:sticky lg:top-6 self-start order-1 lg:order-2">
      <div class="hidden lg:block rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
        <h2 class="text-sm font-bold uppercase tracking-wider text-white/50 mb-3">Datos rápidos</h2>
        <dl class="space-y-2">
          {facts.map(([k, v]) => (
            <div class="flex justify-between gap-3 text-sm">
              <dt class="text-white/45">{k}</dt>
              <dd class="font-semibold text-right">{v}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="rounded-2xl border border-white/[0.08] bg-white/[0.03] p-4">
        <h2 class="text-sm font-bold uppercase tracking-wider text-white/50 mb-3">Qué necesitas para {c.name}</h2>
        <ul class="space-y-4">
          {essentials.map((e) => (
            <li class="border-b border-white/[0.05] last:border-0 pb-4 last:pb-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="text-base">{e.icon}</span>
                <span class="font-semibold text-sm">{e.title}</span>
                <span class={`text-[10px] font-bold uppercase tracking-wide px-2 py-0.5 rounded-full border ${NEED_COLORS[e.need] ?? 'bg-white/[0.08] text-white/60 border-white/15'}`}>{e.need}</span>
              </div>
              <p class="text-xs text-white/55 mt-1.5 leading-relaxed">{e.desc}</p>
              <a href={e.url} target="_blank" rel="noreferrer sponsored"
                 class="mt-2.5 inline-flex items-center gap-1 text-xs font-semibold text-tirma-beige bg-white/[0.05] border border-white/10 rounded-full px-3.5 py-2 hover:border-tirma-pink/40 active:brightness-95 transition">
                {e.linkText} ↗
              </a>
            </li>
          ))}
        </ul>
      </div>

      <a href={`${SITE.appUrl}/dashboard`}
         class="hidden lg:block text-center px-6 py-3.5 rounded-2xl bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold shadow-lg shadow-tirma-pink/25 hover:brightness-105 transition">
        Planifica {c.name} con IA →
      </a>
    </aside>
  </div>

  {related.length > 0 && (
    <section class="max-w-5xl mx-auto px-5 sm:px-6 pb-12">
      <h2 class="text-xl font-bold mb-4">Más destinos que te pueden gustar</h2>
      <div class="grid grid-cols-3 sm:grid-cols-6 gap-3">
        {related.map((r) => (
          <a href={`/destinos/${r.slug}`} class="flex flex-col items-center gap-2 p-3 rounded-2xl bg-white/[0.03] border border-white/[0.08] hover:border-tirma-pink/30 hover:bg-white/[0.05] transition text-center">
            <img src={`https://flagcdn.com/h24/${r.code}.png`} width="34" class="rounded-sm ring-1 ring-white/10" alt={`Bandera de ${r.name}`} />
            <span class="text-xs font-semibold leading-tight">{r.name}</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Barra fija inferior en MÓVIL: el CTA siempre a mano mientras bajas -->
  <div class="lg:hidden h-20" aria-hidden="true"></div>
  <div class="lg:hidden fixed bottom-0 inset-x-0 z-40 px-3 pt-3 bg-[#0a0d12]/92 backdrop-blur border-t border-white/10" style="padding-bottom: calc(0.75rem + env(safe-area-inset-bottom));">
    <a href={`${SITE.appUrl}/dashboard`} class="flex items-center justify-center gap-2 py-3.5 rounded-xl bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold shadow-lg active:brightness-95">
      Planifica {c.name} con IA →
    </a>
  </div>
</Base>
