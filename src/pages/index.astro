---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';

const guias = (await getCollection('guias', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<Base>
  <section class="max-w-5xl mx-auto px-5 sm:px-6 pt-10 sm:pt-16 pb-6 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-tirma-pink/10 border border-tirma-pink/25 text-tirma-beige/90 text-xs font-medium mb-6">
      ✦ Tu referente de viajes
    </div>
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.05] tracking-tight max-w-3xl mx-auto">
      Planifica tu viaje con IA,
      <span class="bg-gradient-to-r from-tirma-pink to-tirma-beige bg-clip-text text-transparent">guías y consejos</span>
    </h1>
    <p class="mt-5 text-base sm:text-lg text-white/65 max-w-xl mx-auto leading-relaxed">
      Crea tu itinerario, calcula el presupuesto y descubre los trucos que de
      verdad ahorran dinero. Todo tu viaje, en un sitio.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 justify-center">
      <a href={SITE.appUrl} class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold shadow-lg shadow-tirma-pink/30 hover:brightness-105 transition">
        Planifica gratis →
      </a>
      <a href="/guias" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full border border-white/15 text-white/80 font-bold hover:border-tirma-pink/40 hover:text-white transition">
        Ver guías
      </a>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-5 sm:px-6 py-12 sm:py-16">
    <div class="text-center mb-8 sm:mb-10">
      <p class="text-xs font-bold tracking-widest text-tirma-pink/80 uppercase mb-3">Guías de viaje</p>
      <h2 class="text-2xl md:text-3xl font-bold">Todo lo que necesitas antes de salir</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {guias.map((g) => (
        <a href={`/guias/${g.slug}`} class="block p-5 rounded-2xl bg-white/[0.03] border border-white/[0.08] hover:border-tirma-pink/30 hover:bg-white/[0.05] transition">
          <div class="text-2xl mb-3">{g.data.emoji}</div>
          <h3 class="font-bold text-base mb-1.5 leading-snug">{g.data.title}</h3>
          <p class="text-sm text-white/60 leading-relaxed line-clamp-3">{g.data.description}</p>
          <span class="inline-block mt-3 text-sm text-tirma-beige/90">Leer guía →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
