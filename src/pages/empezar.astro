---
import Base from '../layouts/Base.astro';
import { SITE } from '../consts';
import { COUNTRIES } from '../data/countries';

const budgetRank: Record<string, number> = { 'Bajo': 1, 'Bajo-medio': 2, 'Medio': 3, 'Medio-alto': 4, 'Alto': 5 };
const data = COUNTRIES.map((c) => ({
  slug: c.slug, name: c.name, code: c.code,
  best: c.bestMonths ?? '', budget: c.budget ?? '',
  rank: budgetRank[c.budget ?? ''] ?? 3,
  tags: c.tags ?? [],
}));
const STYLES = ['Playa', 'Cultura', 'Aventura', 'Gastronómico', 'Naturaleza', 'Solo travel', 'En pareja', 'Barato'];
---

<Base
  title="Empieza aquí: encuentra tu próximo viaje"
  description="¿No sabes a dónde ir? Responde 2 preguntas y te recomendamos tu destino ideal. Después, planifícalo con IA en getcroquis."
>
  <section class="max-w-2xl mx-auto px-5 sm:px-6 pt-10 sm:pt-14 pb-16">
    <p class="text-xs font-bold tracking-widest text-tirma-pink/80 uppercase mb-3">Empieza aquí</p>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Te ayudamos a decidir en 1 minuto</h1>
    <p class="mt-3 text-white/65 leading-relaxed">Responde dos cosas y te decimos a dónde ir. Luego lo planificas con IA.</p>

    <!-- Paso 1 -->
    <div class="mt-8">
      <h2 class="font-bold mb-1"><span class="text-tirma-pink">1.</span> ¿Qué te apetece?</h2>
      <p class="text-xs text-white/45 mb-3">Elige uno o varios.</p>
      <div id="styles" class="flex flex-wrap gap-2">
        {STYLES.map((s) => (
          <button data-style={s} class="opt px-3.5 py-2 rounded-full text-sm font-semibold border transition">{s}</button>
        ))}
      </div>
    </div>

    <!-- Paso 2 -->
    <div class="mt-7">
      <h2 class="font-bold mb-3"><span class="text-tirma-pink">2.</span> ¿Presupuesto?</h2>
      <div id="budget" class="flex flex-wrap gap-2">
        <button data-max="2" class="optb px-3.5 py-2 rounded-full text-sm font-semibold border transition">💸 Ajustado</button>
        <button data-max="3" class="optb px-3.5 py-2 rounded-full text-sm font-semibold border transition">🙂 Medio</button>
        <button data-max="5" class="optb px-3.5 py-2 rounded-full text-sm font-semibold border transition">✨ Sin límite</button>
      </div>
    </div>

    <button id="go" class="mt-8 w-full py-3.5 rounded-full bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold shadow-lg shadow-tirma-pink/30 hover:brightness-105 transition">
      Ver mis destinos ideales →
    </button>

    <!-- Resultado -->
    <div id="result" class="mt-10 hidden">
      <h2 class="text-2xl font-bold mb-4">Tus destinos ✨</h2>
      <div id="cards" class="grid sm:grid-cols-2 gap-3"></div>
      <div class="mt-8 text-center rounded-2xl bg-gradient-to-br from-tirma-pink/12 to-transparent border border-tirma-pink/25 p-6">
        <p class="font-bold text-lg">¿Ya lo tienes más claro?</p>
        <p class="text-sm text-white/65 mt-1">Crea tu cuenta y planifica el viaje con IA en minutos.</p>
        <a href={`${SITE.appUrl}/signup`} class="inline-block mt-4 px-7 py-3 rounded-full bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold hover:brightness-105 transition">Crear cuenta gratis →</a>
      </div>
    </div>
  </section>

  <style>
    .opt, .optb { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); }
    .opt:hover, .optb:hover { border-color: rgba(230,21,127,0.4); }
    .opt.on, .optb.on { background: #C30F68; border-color: #C30F68; color: #F1E2B3; }
  </style>

  <script define:vars={{ data }}>
    let styles = [];
    let maxBudget = 5;
    document.querySelectorAll('.opt').forEach((b) => b.addEventListener('click', () => {
      b.classList.toggle('on');
      const s = b.dataset.style;
      styles = styles.includes(s) ? styles.filter((x) => x !== s) : [...styles, s];
    }));
    document.querySelectorAll('.optb').forEach((b) => b.addEventListener('click', () => {
      document.querySelectorAll('.optb').forEach((x) => x.classList.remove('on'));
      b.classList.add('on');
      maxBudget = parseInt(b.dataset.max, 10);
    }));

    document.getElementById('go').addEventListener('click', () => {
      let matches = data.filter((c) => c.rank <= maxBudget && (styles.length === 0 || c.tags.some((t) => styles.includes(t))));
      if (matches.length === 0) matches = data.filter((c) => c.rank <= maxBudget);
      const cards = document.getElementById('cards');
      cards.innerHTML = matches.map((c) => `
        <a href="/destinos/${c.slug}" class="flex items-center gap-3 p-4 rounded-2xl bg-white/[0.03] border border-white/[0.08] hover:border-tirma-pink/30 hover:bg-white/[0.05] transition">
          <img src="https://flagcdn.com/h20/${c.code}.png" width="28" class="rounded-sm ring-1 ring-white/10" alt="" />
          <div class="min-w-0">
            <div class="font-bold text-sm truncate">${c.name}</div>
            <div class="text-[11px] text-white/45 truncate">${c.best}</div>
          </div>
        </a>`).join('');
      const r = document.getElementById('result');
      r.classList.remove('hidden');
      r.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  </script>
</Base>
