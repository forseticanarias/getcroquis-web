---
import Base from '../layouts/Base.astro';
import { COUNTRIES } from '../data/countries';

const data = COUNTRIES.map((c) => ({
  slug: c.slug,
  name: c.name,
  code: c.code,
  best: c.bestMonths ?? '—',
  budget: c.budget ?? '—',
  perDay: c.budgetLevels ? `${c.budgetLevels.normal}€/día` : '—',
  language: c.language ?? '—',
  currency: c.currency ?? '—',
  duration: c.duration ?? '—',
  difficulty: c.difficulty ?? '—',
  tags: (c.tags ?? []).slice(0, 3),
})).sort((a, b) => a.name.localeCompare(b.name));
---

<Base
  title="Comparar países para viajar"
  description="¿Dudas entre varios destinos? Elige hasta 3 países y compara sus datos esenciales lado a lado: mejor época, presupuesto y dificultad."
>
  <section class="max-w-4xl mx-auto px-5 sm:px-6 pt-10 sm:pt-14 pb-4">
    <p class="text-xs font-bold tracking-widest text-tirma-pink/80 uppercase mb-3">¿No te decides?</p>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Compara y decídete</h1>
    <p class="mt-3 text-white/65 leading-relaxed">¿Dudas entre dos o tres destinos? Elígelos abajo y mira sus datos esenciales <strong class="text-white/80">lado a lado</strong>.</p>
  </section>

  <section class="max-w-4xl mx-auto px-5 sm:px-6 pb-16">
    <div class="relative mb-4">
      <input id="search" type="search" placeholder="Busca un país…" autocomplete="off"
        class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-white/[0.06] border border-white/15 text-white placeholder-white/40 outline-none focus:border-tirma-pink/50" />
      <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-white/40 pointer-events-none">🔍</span>
    </div>

    <div id="picker" class="flex flex-wrap gap-2 mb-6">
      {data.map((c) => (
        <button data-slug={c.slug} data-name={c.name.toLowerCase()} class="pick-btn inline-flex items-center gap-2 px-3 py-2 rounded-full text-sm font-semibold border transition">
          <img src={`https://flagcdn.com/h20/${c.code}.png`} alt="" width="20" class="rounded-sm ring-1 ring-white/10" />
          {c.name}
        </button>
      ))}
    </div>

    <p id="hint" class="text-white/45 text-sm py-8 text-center">👆 Elige hasta 3 países para compararlos.</p>
    <div id="compare" class="grid gap-3" style="grid-template-columns:repeat(auto-fit,minmax(0,1fr));"></div>
  </section>

  <style>
    .pick-btn { background: rgba(255,255,255,0.04); border-color: rgba(255,255,255,0.1); color: rgba(255,255,255,0.75); }
    .pick-btn:hover { border-color: rgba(230,21,127,0.4); }
    .pick-btn.on { background: #C30F68; border-color: #C30F68; color: #F1E2B3; }
    .pick-btn.dim { opacity: 0.4; }
  </style>

  <script define:vars={{ data }}>
    const bySlug = Object.fromEntries(data.map((c) => [c.slug, c]));
    const picker = document.getElementById('picker');
    const compare = document.getElementById('compare');
    const hint = document.getElementById('hint');
    let selected = [];

    function row(label, value) {
      return `<div class="flex justify-between gap-2 py-1.5 border-b border-white/[0.05] text-sm"><span class="text-white/40">${label}</span><span class="font-semibold text-right">${value}</span></div>`;
    }

    function render() {
      hint.style.display = selected.length ? 'none' : '';
      compare.innerHTML = selected.map((slug) => {
        const c = bySlug[slug];
        const tags = c.tags.map((t) => `<span class="px-2 py-0.5 rounded-full bg-white/[0.06] text-[11px] text-white/60">${t}</span>`).join(' ');
        return `<div class="rounded-2xl bg-white/[0.03] border border-white/[0.08] p-4">
          <div class="flex items-center gap-2 mb-3">
            <img src="https://flagcdn.com/h20/${c.code}.png" width="24" class="rounded-sm ring-1 ring-white/10" alt="" />
            <span class="font-bold text-lg">${c.name}</span>
          </div>
          ${row('Mejor época', c.best)}
          ${row('Coste', c.budget)}
          ${row('€/día (medio)', c.perDay)}
          ${row('Duración ideal', c.duration)}
          ${row('Idioma', c.language)}
          ${row('Moneda', c.currency)}
          ${row('Dificultad', c.difficulty)}
          <div class="flex flex-wrap gap-1 mt-2">${tags}</div>
          <a href="/destinos/${c.slug}" class="block text-center mt-4 px-4 py-2.5 rounded-xl bg-gradient-to-r from-tirma-pink to-tirma-deep text-tirma-beige font-bold text-sm hover:brightness-105 transition">Ver ficha completa →</a>
        </div>`;
      }).join('');
    }

    function updateButtons() {
      const full = selected.length >= 3;
      picker.querySelectorAll('.pick-btn').forEach((b) => {
        const on = selected.includes(b.dataset.slug);
        b.classList.toggle('on', on);
        b.classList.toggle('dim', full && !on);
      });
    }

    picker.querySelectorAll('.pick-btn').forEach((b) => b.addEventListener('click', () => {
      const slug = b.dataset.slug;
      if (selected.includes(slug)) selected = selected.filter((s) => s !== slug);
      else if (selected.length < 3) selected.push(slug);
      updateButtons();
      render();
    }));

    const search = document.getElementById('search');
    search.addEventListener('input', () => {
      const q = search.value.trim().toLowerCase();
      picker.querySelectorAll('.pick-btn').forEach((b) => {
        b.style.display = b.dataset.name.includes(q) ? '' : 'none';
      });
    });
  </script>
</Base>
