---
import Base from '../layouts/Base.astro';
import { COUNTRIES } from '../data/countries';

// Estilos destacados (recomendaciones por criterio). Cada uno agrupa países con
// ese tag. Pensado para inspirar a quien no tiene claro a dónde ir.
const STYLES: { tag: string; emoji: string; title: string }[] = [
  { tag: 'Playa', emoji: '🏖️', title: 'Para playa y relax' },
  { tag: 'Cultura', emoji: '🏛️', title: 'Para amantes de la cultura' },
  { tag: 'Gastronómico', emoji: '🍜', title: 'Para comerte el viaje' },
  { tag: 'Aventura', emoji: '🥾', title: 'Para aventureros' },
  { tag: 'Naturaleza', emoji: '🏔️', title: 'Para amantes de la naturaleza' },
  { tag: 'Barato', emoji: '💸', title: 'Para viajar barato' },
  { tag: 'Solo travel', emoji: '🧳', title: 'Para viajar solo/a (seguros)' },
  { tag: 'En pareja', emoji: '❤️', title: 'Para escapada en pareja' },
  { tag: 'Bueno para primerizos', emoji: '🌱', title: 'Para primerizos' },
];

const groups = STYLES
  .map((s) => ({ ...s, countries: COUNTRIES.filter((c) => (c.tags ?? []).includes(s.tag)) }))
  .filter((g) => g.countries.length > 0);
---

<Base
  title="Ideas de viaje por estilo: playa, cultura, aventura…"
  description="¿No sabes a dónde ir? Encuentra tu destino ideal por estilo de viaje: playa, cultura, aventura, viajar solo, barato, en pareja y más."
>
  <section class="max-w-4xl mx-auto px-5 sm:px-6 pt-10 sm:pt-14 pb-6">
    <p class="text-xs font-bold tracking-widest text-tirma-pink/80 uppercase mb-3">Inspírate</p>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">¿Qué tipo de viaje buscas?</h1>
    <p class="mt-3 text-white/65 leading-relaxed">Destinos recomendados según tu estilo. Elige el que te encaje y mira su ficha completa.</p>
  </section>

  <section class="max-w-4xl mx-auto px-5 sm:px-6 pb-16 space-y-10">
    {groups.map((g) => (
      <div>
        <h2 class="text-xl sm:text-2xl font-bold mb-4">{g.emoji} {g.title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {g.countries.map((c) => (
            <a href={`/destinos/${c.slug}`} class="flex items-center gap-3 p-3 rounded-2xl bg-white/[0.03] border border-white/[0.08] hover:border-tirma-pink/30 hover:bg-white/[0.05] transition">
              <img src={`https://flagcdn.com/h20/${c.code}.png`} alt="" width="26" class="rounded-sm ring-1 ring-white/10" />
              <div class="min-w-0">
                <div class="font-bold text-sm truncate">{c.name}</div>
                {c.bestMonths && <div class="text-[11px] text-white/45 truncate">{c.bestMonths}</div>}
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>
</Base>
